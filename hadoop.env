# CORE CONFIG
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
CORE_CONF_hadoop_http_staticuser_user=root
CORE_CONF_hadoop_proxyuser_hue_hosts=*
CORE_CONF_hadoop_proxyuser_hue_groups=*

# HDFS CONFIG
HDFS_CONF_dfs_replication=1
HDFS_CONF_dfs_namenode_name_dir=file:///hadoop/dfs/name
HDFS_CONF_dfs_datanode_data_dir=file:///hadoop/dfs/data

# YARN CONFIG
YARN_CONF_yarn_resourcemanager_hostname=resourcemanager
YARN_CONF_yarn_nodemanager_resource_memory_mb=2048
YARN_CONF_yarn_scheduler_maximum_allocation_mb=2048
YARN_CONF_yarn_resourcemanager_bind_host=0.0.0.0

# MAPREDUCE CONFIG
MAPRED_CONF_mapreduce_framework_name=yarn
MAPRED_CONF_mapreduce_map_memory_mb=512
MAPRED_CONF_mapreduce_reduce_memory_mb=512

HADOOP_MAPRED_HOME=/opt/hadoop-3.2.1
MAPRED_CONFIG__yarn_app_mapreduce_am_env=HADOOP_MAPRED_HOME=/opt/hadoop-3.2.1
MAPRED_CONFIG__mapreduce_map_env=HADOOP_MAPRED_HOME=/opt/hadoop-3.2.1
MAPRED_CONFIG__mapreduce_reduce_env=HADOOP_MAPRED_HOME=/opt/hadoop-3.2.1

YARN_CONFIG_yarn_nodemanager_aux_services=mapreduce_shuffle
YARN_CONFIG_yarn_nodemanager_aux_services_mapreduce_shuffle_class=org.apache.hadoop.mapred.ShuffleHandler